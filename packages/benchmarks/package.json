{
  "name": "@styled-components/benchmarks",
  "private": true,
  "scripts": {
    "build": "webpack-cli --config webpack.config.js",
    "open": "open ./index.html",
    "bench:headless": "pnpm bench:headless:creation && pnpm bench:headless:ssr && pnpm bench:headless:rsc",
    "bench:headless:creation": "node --expose-gc headless/creation.mjs",
    "bench:headless:ssr": "node --expose-gc headless/ssr.mjs",
    "bench:headless:rsc": "node --expose-gc headless/rsc.mjs"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "classnames": "2.5.1",
    "d3-scale-chromatic": "3.1.0",
    "goober": "2.1.18",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-is": "^19.0.0",
    "react-native-web": "^0.21.2",
    "styled-components": "workspace:*",
    "styled-components-v6": "npm:styled-components@6.4.1",
    "styled-jsx": "5.1.7"
  },
  "devDependencies": {
    "@babel/core": "^7.24.5",
    "@tailwindcss/webpack": "4.2.4",
    "babel-loader": "^9.1.3",
    "babel-plugin-module-resolver": "^4.1.0",
    "babel-plugin-react-native-web": "^0.21.2",
    "css-loader": "^6.11.0",
    "mitata": "1.0.34",
    "source-map-loader": "^4.0.2",
    "style-loader": "^3.3.4",
    "tailwindcss": "4.2.4",
    "webpack": "^5.105.4",
    "webpack-cli": "^5.1.4"
  },
  "sideEffects": [
    "*.css"
  ],
  "engines": {
    "node": ">=20"
  }
}
